{
  "name": "jmock",
  "version": "1.0.4",
  "description": "A simple command-line http server for mocking data, proxying requests and serving static files",
  "main": "./lib/jmock",
  "repository": {
    "type": "git",
    "url": "git://github.com/Yakima-Teng/jmock.git"
  },
  "keywords": [
    "cli",
    "command",
    "static",
    "http",
    "https",
    "http-server",
    "https-server",
    "server",
    "mock",
    "proxy",
    "jmock"
  ],
  "scripts": {
    "ready": "npm install",
    "start": "node ./bin/jmock -p 8081 --config",
    "test": "node --test test/*.test.js",
    "test-watch": "node --test --watch test/*.test.js",
    "deploy:github": "bash bash/github-deploy.sh",
    "deploy:qiniu": "node build/deploy.mjs",
    "deploy:npm": "npm --registry=https://registry.npmjs.org publish",
    "deploy": "npm run deploy:qiniu && npm run deploy:github && npm run deploy:npm",
    "lint:markdown": "markdownlint-cli2",
    "format": "prettier . --write",
    "lint:code": "eslint . --fix",
    "typecheck": "echo 'No TypeScript configuration found, skipping type check'",
    "lint": "npm run format && npm run lint:code && npm run lint:markdown && npm run typecheck && npm run test"
  },
  "files": [
    "lib",
    "bin",
    "jmock.config.js",
    "README.md",
    "LICENSE",
    "NOTICE",
    "package.json",
    "package-lock.json"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "contributors": [
    {
      "name": "Yakima Teng",
      "email": "yakima.public@gmail.com"
    }
  ],
  "dependencies": {
    "basic-auth": "^2.0.1",
    "chalk": "^4.1.2",
    "co-body": "^6.1.0",
    "corser": "^2.0.1",
    "he": "^1.2.0",
    "html-encoding-sniffer": "^3.0.0",
    "http-proxy": "^1.18.1",
    "mime": "^1.6.0",
    "minimist": "^1.2.6",
    "mockjs": "^1.1.0",
    "opener": "^1.5.1",
    "portfinder": "^1.0.28",
    "secure-compare": "3.0.1",
    "union": "~0.5.0",
    "url-join": "^4.0.1"
  },
  "devDependencies": {
    "better-deploy": "^0.0.15",
    "eol": "^0.9.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "express": "^4.17.1",
    "markdownlint-cli2": "^0.13.0",
    "prettier": "3.9.5",
    "request": "^2.88.2"
  },
  "bugs": {
    "url": "https://github.com/Yakima-Teng/jmock/issues"
  },
  "license": "Apache-2.0",
  "preferGlobal": true,
  "bin": {
    "jmock": "./bin/jmock"
  }
}
