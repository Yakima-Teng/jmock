{
  "name": "jmock",
  "version": "2.0.0",
  "description": "A simple command-line http server for mocking data, proxying requests and serving static files",
  "type": "module",
  "main": "./lib/jmock.ts",
  "repository": {
    "type": "git",
    "url": "git://github.com/Yakima-Teng/jmock.git"
  },
  "keywords": [
    "cli",
    "command",
    "static",
    "http",
    "https",
    "http-server",
    "https-server",
    "server",
    "mock",
    "proxy",
    "jmock"
  ],
  "scripts": {
    "ready": "npm install",
    "start": "node ./bin/jmock -p 8081 --config",
    "test": "node --test test/*.test.ts",
    "test-watch": "node --test --watch test/*.test.ts",
    "lint": "npm run format && npm run lint:code && npm run lint:markdown && npm run typecheck && npm run test",
    "lint:markdown": "markdownlint-cli2",
    "format": "prettier . --write",
    "lint:code": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "release-major": "standard-version --release-as major",
    "release-minor": "standard-version --release-as minor",
    "release-patch": "standard-version --release-as patch",
    "deploy:tags": "git push --follow-tags origin main",
    "deploy:npm": "node ./scripts/deploy-npm.ts",
    "deploy": "node --run deploy:tags && node --run deploy:npm"
  },
  "files": [
    "lib",
    "bin",
    "jmock.config.mjs",
    "README.md",
    "LICENSE",
    "NOTICE",
    "package.json",
    "package-lock.json"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "contributors": [
    {
      "name": "Yakima Teng",
      "email": "yakima.public@gmail.com"
    }
  ],
  "dependencies": {
    "basic-auth": "^2.0.1",
    "chalk": "^4.1.2",
    "co-body": "^6.1.0",
    "corser": "^2.0.1",
    "he": "^1.2.0",
    "html-encoding-sniffer": "^3.0.0",
    "http-proxy": "^1.18.1",
    "mime": "^1.6.0",
    "minimist": "^1.2.6",
    "mockjs": "^1.1.0",
    "nsuite": "0.2.5",
    "opener": "^1.5.1",
    "portfinder": "^1.0.28",
    "secure-compare": "3.0.1",
    "union": "~0.5.0",
    "url-join": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "better-deploy": "^0.0.15",
    "eol": "^0.9.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "express": "^4.17.1",
    "markdownlint-cli2": "^0.13.0",
    "prettier": "3.9.5",
    "request": "^2.88.2",
    "standard-version": "9.5.0",
    "typescript": "^5.7.0"
  },
  "bugs": {
    "url": "https://github.com/Yakima-Teng/jmock/issues"
  },
  "license": "Apache-2.0",
  "preferGlobal": true,
  "bin": {
    "jmock": "./bin/jmock"
  }
}
