{
  "root": true,
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "strict": "warn",
    "no-console": "warn",
    "no-undefined": "warn",
    "no-nested-ternary": "warn",
    "callback-return": ["warn", ["next"]]
  },
  "ignorePatterns": ["node_modules/"]
}
